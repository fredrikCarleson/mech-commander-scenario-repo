# Google OAuth (Web application client — used for admin sign-in)
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Comma-separated admin emails allowed to approve uploads
ADMIN_EMAILS=fredrik.carleson@gmail.com

# Optional: bearer token for scripted admin access / local testing
# ADMIN_API_KEY=

# Optional upload rate limits
# UPLOAD_RATE_LIMIT=10
# UPLOAD_RATE_WINDOW_MS=3600000

# Blob store override (optional)
# SCENARIO_BLOB_STORE=mech-scenarios
